{
  "name": "devflow-suite",
  "displayName": "DevFlow-Suite",
  "description": "A minimalist, backendless VS Code extension for TODO management and Git visualization.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
  "views": {
    "devflow-suite-sidebar": [
      { "id": "todo-explorer", "name": "DevFlow Workspace" }
    ]
  },
  "commands": [
    { "command": "devflow-suite.addManualTodo", "title": "Add Personal Task", "icon": "$(add)" },
    { "command": "devflow-suite.exportTasks", "title": "Export to Markdown", "icon": "$(export)" },
    { "command": "devflow-suite.deleteTask", "title": "Move to Trash", "icon": "$(trash)" },
    { "command": "devflow-suite.copyTask", "title": "Copy Task", "icon": "$(copy)" }
  ],
  "menus": {
    "view/item/context": [
      { "command": "devflow-suite.copyTask", "when": "view == todo-explorer", "group": "inline" },
      { "command": "devflow-suite.deleteTask", "when": "view == todo-explorer && viewItem == manualTodo", "group": "inline" }
    ],
    "view/title": [
      { "command": "devflow-suite.addManualTodo", "when": "view == todo-explorer", "group": "navigation" },
      { "command": "devflow-suite.exportTasks", "when": "view == todo-explorer", "group": "navigation" }
    ]
  }
}
}