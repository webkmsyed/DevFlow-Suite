{
  "name": "devflow-suite",
  "displayName": "DevFlow-Suite",
  "description": "A minimalist, backendless VS Code extension for TODO management and Git visualization.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devflow-suite-sidebar",
          "title": "DevFlow Suite",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "devflow-suite-sidebar": [
        {
          "id": "todo-explorer",
          "name": "Smart TODOs",
          "visibility": "visible"
        },
        {
          "id": "git-visualizer",
          "name": "Git Tree Explorer",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "devflow-suite.refreshTodo",
        "title": "Refresh TODOs",
        "icon": "$(refresh)"
      },
      {
        "command": "devflow-suite.addManualTodo",
        "title": "Add Global Task",
        "icon": "$(add)"
      },
      {
        "command": "devflow-suite.exportTasks",
        "title": "Share Tasks to Notion",
        "icon": "$(export)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devflow-suite.addManualTodo",
          "when": "view == todo-explorer",
          "group": "navigation"
        },
        {
          "command": "devflow-suite.exportTasks",
          "when": "view == todo-explorer",
          "group": "navigation"
        },
        {
          "command": "devflow-suite.refreshTodo",
          "when": "view == todo-explorer",
          "group": "navigation"
        }
      ]
    }
  }
}